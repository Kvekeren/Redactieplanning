// learn more about it in the docs: https://pris.ly/d/prisma-schema

// PostgreSQL voor Neon/Vercel

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id           String   @id @default(cuid())
  datum        String   // YYYY-MM-DD
  onderwerp    String
  url          String?  // optionele url van het artikel
  naam         String   @default("")  // Lizanne, Govert, Iona, Helga, Koen
  status       String   @default("")  // Mee bezig, Gepubliceerd, Ingepland
  categorie    String   @default("")
  rerun        Boolean  @default(false)
  opmerkingen  String?  @default("")
  positie      Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
